{
  "name": "pi-cyber-ui",
  "version": "0.1.15",
  "description": "Standalone Pi UI package with a cyber-inspired theme, custom editor, footer, and lightweight working indicator.",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "files": [
    "themes",
    "extensions",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "prepare": "npm run typecheck"
  },
  "pi": {
    "themes": [
      "./themes"
    ],
    "extensions": [
      "./extensions/pi-cyber-ui/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "typescript": "^5.7.3"
  }
}
